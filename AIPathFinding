local Network = {}

local inputSize = 4 -- dx, dz, blocked, distance
local hiddenSize = 8
local outputSize = 1

local learningRate = 0.01
local Random = Random.new(os.clock())

local function relu(x)
	return (x > 0) and x or 0.01 * x
end

local function reluDerivative(x)
	return (x > 0) and 1 or 0.01
end

local function newNeuron(prevSize)
	local n = {
		value = 0,
		sum = 0,
		delta = 0,
		bias = Random:NextNumber()*2-1,
		weights = {}
	}

	for i=1,(prevSize or 0) do
		n.weights[i] = Random:NextNumber()*2-1
	end

	return n
end

Network.layers = {
	{}, {}, {}
}

for i=1,inputSize do
	Network.layers[1][i] = newNeuron()
end

for i=1,hiddenSize do
	Network.layers[2][i] = newNeuron(inputSize)
end

for i=1,outputSize do
	Network.layers[3][i] = newNeuron(hiddenSize)
end

function Network.feed(input)
	for i,n in ipairs(Network.layers[1]) do
		n.value = input[i]
	end

	for l=2,#Network.layers do
		local layer = Network.layers[l]
		local prev = Network.layers[l-1]

		for _,n in ipairs(layer) do
			local sum = n.bias

			for i,p in ipairs(prev) do
				sum += p.value * n.weights[i]
			end

			n.sum = sum
			n.value = relu(sum)
		end
	end

	return Network.layers[#Network.layers][1].value
end

function Network.backprop(target)
	local out = Network.layers[#Network.layers][1]
	local err = out.value - target

	out.delta = err * reluDerivative(out.sum)

	for l=#Network.layers-1,2,-1 do
		local layer = Network.layers[l]
		local nextLayer = Network.layers[l+1]

		for i,n in ipairs(layer) do
			local e = 0
			for _,nx in ipairs(nextLayer) do
				e += nx.weights[i] * nx.delta
			end
			n.delta = e * reluDerivative(n.sum)
		end
	end

	for l=2,#Network.layers do
		local layer = Network.layers[l]
		local prev = Network.layers[l-1]

		for _,n in ipairs(layer) do
			for i,p in ipairs(prev) do
				n.weights[i] -= learningRate * n.delta * p.value
			end
			n.bias -= learningRate * n.delta
		end
	end
end

local HttpService = game:GetService("HttpService")

function Network:Save()
	local data = {}

	for l, layer in ipairs(self.layers) do
		data[l] = {}
		for i, neuron in ipairs(layer) do
			data[l][i] = {
				bias = neuron.bias,
				weights = neuron.weights
			}
		end
	end

	local json = HttpService:JSONEncode(data)

	if writefile then
		writefile("DeepPS.json", json)
	end
end

function Network:Load()
	if readfile and isfile and isfile("DeepPS.json") then
		local json = readfile("DeepPS.json")
		local data = HttpService:JSONDecode(json)

		for l, layer in ipairs(self.layers) do
			for i, neuron in ipairs(layer) do
				neuron.bias = data[l][i].bias
				neuron.weights = data[l][i].weights
			end
		end
	end
end

Network:Load()

local Pathfinding = {}

local paramsRay = RaycastParams.new()
paramsRay.FilterType = Enum.RaycastFilterType.Blacklist

local function heuristic(a, b)
	return (a - b).Magnitude
end

local function key(v, step)
	return math.floor(v.X/step) .. "," .. math.floor(v.Z/step)
end

local function getCharacterSize(character)
	local size = character:GetExtentsSize()
	return Vector3.new(size.X, size.Y, size.Z)
end

local function isWalkable(from, to, ignore)
	local dir = (to - from)
	local dist = dir.Magnitude

	if dist < 0.001 then
		return true
	end

	paramsRay.FilterDescendantsInstances = ignore or {}

	local result = workspace:Raycast(
		from + Vector3.new(0,2,0),
		dir.Unit * dist,
		paramsRay
	)

	return result == nil
end

local function canFit(pos, size, ignore, character)
	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist

	local filter = {character}
	if ignore then
		for _,v in ipairs(ignore) do
			table.insert(filter, v)
		end
	end

	params.FilterDescendantsInstances = filter

	local parts = workspace:GetPartBoundsInBox(
		CFrame.new(pos + Vector3.new(0, size.Y/2, 0)),
		size,
		params
	)

	for _,part in ipairs(parts) do
		if part:IsDescendantOf(character) then
			continue
		end

		if part:IsA("BasePart") and part.CanCollide and part.Transparency < 1 then
			return false
		end
	end

	return true
end

local function getClearancePenalty(pos, dir, spacing, ignore)
	if spacing <= 0 then return 0 end

	local right = dir.Magnitude > 0 and dir:Cross(Vector3.new(0,1,0)).Unit or Vector3.zero

	paramsRay.FilterDescendantsInstances = ignore or {}

	local function hit(offset)
		local r = workspace:Raycast(
			pos + offset + Vector3.new(0,2,0),
			Vector3.new(0,-4,0),
			paramsRay
		)
		return r and 1 or 0
	end

	return (hit(right * spacing) + hit(-right * spacing)) * spacing
end

local function neighbors(pos, step)
	return {
		pos + Vector3.new(step,0,0),
		pos + Vector3.new(-step,0,0),
		pos + Vector3.new(0,0,step),
		pos + Vector3.new(0,0,-step),

		pos + Vector3.new(step,0,step),
		pos + Vector3.new(-step,0,step),
		pos + Vector3.new(step,0,-step),
		pos + Vector3.new(-step,0,-step),
	}
end

function Pathfinding:GetNNBias(input)
	if not Network then return 0 end
	return math.tanh(Network.feed(input))
end

function Pathfinding:FindPath(character, startPos, goalPos, params)
	params = params or {}

	local step = params.Step or 4
	local spacing = params.Spacing or 2
	local ignore = params.Ignore or {}

	local charSize = getCharacterSize(character) * 0.8

	local open = {}
	local closed = {}

	open[key(startPos, step)] = {
		pos = startPos,
		g = 0,
		f = heuristic(startPos, goalPos)
	}

	local iterations = 0
	local maxIterations = 5000

	while iterations < maxIterations do
		iterations += 1

		local currentKey, current

		for k,v in pairs(open) do
			if not current or v.f < current.f then
				current = v
				currentKey = k
			end
		end

		if not current then
			return nil
		end

		if (current.pos - goalPos).Magnitude < step * 2 then
			local path = {}
			while current do
				table.insert(path,1,current.pos)
				current = current.parent
			end
			return path
		end

		open[currentKey] = nil
		closed[currentKey] = true

		local added = false

		for _,nPos in ipairs(neighbors(current.pos, step)) do
			local nk = key(nPos, step)
			if closed[nk] then continue end

			local dir = (nPos - current.pos)

			if math.abs(dir.X) > 0 and math.abs(dir.Z) > 0 then
				local side1 = current.pos + Vector3.new(dir.X,0,0)
				local side2 = current.pos + Vector3.new(0,0,dir.Z)

				if not isWalkable(current.pos, side1, ignore)
				or not isWalkable(current.pos, side2, ignore) then
					continue
				end
			end

			if not isWalkable(current.pos, nPos, ignore) then
				continue
			end

			if not canFit(nPos, charSize, ignore, character) then
				continue
			end

			added = true

			local moveCost = (dir.Magnitude > step) and 1.4 or 1
			local g = current.g + moveCost
			local h = heuristic(nPos, goalPos)

			local clearance = getClearancePenalty(nPos, dir, spacing, ignore)

			local f = g + h + clearance

			if params.MachineLearning then
				local toGoal = goalPos - nPos

				local input = {
					math.clamp(toGoal.X/50,-1,1),
					math.clamp(toGoal.Z/50,-1,1),
					0,
					math.clamp(toGoal.Magnitude/50,0,1)
				}

				local nn = self:GetNNBias(input)
				f += nn * 0.5 * h
			end

			if not open[nk] or g < open[nk].g then
				open[nk] = {
					pos = nPos,
					g = g,
					f = f,
					parent = current
				}
			end
		end

		if not added then
			for _,nPos in ipairs(neighbors(current.pos, step)) do
				local nk = key(nPos, step)
				if not closed[nk] then
					open[nk] = {
						pos = nPos,
						g = current.g + 1,
						f = current.g + heuristic(nPos, goalPos),
						parent = current
					}
				end
			end
		end
	end

	return nil
end

Network.Pathfinding = Pathfinding

return Network
